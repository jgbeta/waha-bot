# WAHA
WAHA_IMAGE=devlikeapro/waha
WAHA_HOST_PORT=3000
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=CHANGE_ME
WAHA_SESSION=default
WAHA_TIMEOUT_SECONDS=15
WAHA_SEND_RETRIES=3
WAHA_WEBHOOK_URL=http://bot:8000/webhook
# Optional. Leave blank for first local validation; set a shared secret for real deployments.
WAHA_WEBHOOK_HMAC_KEY=
WHATSAPP_HOOK_EVENTS=message,session.status

WAHA_DASHBOARD_ENABLED=true
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=CHANGE_ME

# OpenAI-compatible API
OPENAI_API_KEY=CHANGE_ME
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini-2025-04-14
OPENAI_MAX_TOKENS=2048
OPENAI_TIMEOUT_SECONDS=30
OPENAI_RETRIES=2

# Bot access control
# Use country code and digits only. Multiple values are comma-separated.
BOT_ALLOWED_PHONES=12025550123
BOT_ALLOWED_CHAT_IDS=
BOT_REQUIRE_ALLOWLIST=true
BOT_ALLOW_GROUPS=false

# Storage: SQLite is the default and needs no external database.
BOT_STORE=sqlite
BOT_SQLITE_PATH=/data/bot.sqlite3
BOT_HISTORY_STORE=sqlite
BOT_RETAIN_PROCESSED_MESSAGE_BODY=false

# PostgreSQL DB setup, optional.
# To use this mode, uncomment and fill these values, then rebuild with:
# docker compose up -d --build
# BOT_STORE=postgres
# BOT_HISTORY_STORE=postgres
# PG_HOST=PostgreSQL_IP
# PG_PORT=5432
# PG_USER=postgres_username
# PG_PASSWORD=postgres_password
# PG_DBNAME=database_name
# PG_TABLE=table_name
# PG_CONTACT_NAME=contact_name
# PG_CONTACT_NAME is a legacy label written to the Postgres table usr column for user messages.
# It is not the WhatsApp phone ID and does not replace BOT_ALLOWED_PHONES/BOT_ALLOWED_CHAT_IDS.

# Behavior
BOT_CLEAR_COMMAND=clear history
BOT_CLEAR_REPLY=History cleared.
BOT_HISTORY_MAX_MESSAGES=20
BOT_SYSTEM_PROMPT_FILE=/app/prompts/system.md
BOT_SYSTEM_PROMPT=
BOT_QUEUE_MAXSIZE=100
BOT_DEDUPE_TTL_SECONDS=86400
BOT_LID_CACHE_TTL_SECONDS=86400
BOT_SEND_SEEN=true
BOT_SEND_TYPING=true
BOT_ERROR_REPLY=Sorry, I had trouble generating a reply. Please try again.
BOT_AUTOREPLY_ENABLED=true
BOT_DRY_RUN=false

# Logs
LOG_LEVEL=INFO
